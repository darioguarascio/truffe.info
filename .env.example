# Local development with docker compose postgresql
POSTGRES_USER=truffe
POSTGRES_PASSWORD=truffe
POSTGRES_DB=truffe
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://truffe:truffe@localhost:5432/truffe
HOST=0.0.0.0
PORT=4321
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=25

# Email (admin notifications and moderation)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@truffe.info
ADMIN_EMAIL=

# Bearer token for moderation API (PATCH /api/admin/moderation)
ADMIN_TOKEN=

# Optional public contact email shown on /contatti (default: ciao@truffe.info)
PUBLIC_CONTACT_EMAIL=ciao@truffe.info
