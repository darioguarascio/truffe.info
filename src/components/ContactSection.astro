---
import ContactForm from './ContactForm.astro';
import { GITHUB_ISSUES_URL, GITHUB_URL, MAINTAINER_NAME } from '../lib/site';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section
  class:list={[
    'contact-section',
    compact ? 'contact-section--compact' : 'page-container py-16 md:py-20',
  ]}
  aria-labelledby="contact-heading"
>
  <div class:list={[compact ? 'max-w-3xl' : 'max-w-4xl', 'mx-auto']}>
    <p class="section-label mb-3">Contatti</p>
    <h2 id="contact-heading" class:list={['font-display font-bold text-ink tracking-tight mb-3', compact ? 'text-2xl' : 'text-3xl md:text-4xl']}>
      {compact ? 'Vuoi parlare con chi gestisce il progetto?' : 'Mettiti in contatto'}
    </h2>
    <p class="text-ink-muted leading-relaxed mb-8 max-w-2xl">
      {compact
        ? 'Per collaborazioni, segnalazioni tecniche o domande sul sito — non per raccontare una truffa subita.'
        : `${MAINTAINER_NAME} cura Truffe.info come progetto open source. Scrivi per collaborazioni, media, bug del sito o proposte di miglioramento.`}
    </p>

    {compact ? (
      <a href="/contatti#contatto" class="btn-primary text-sm">Scrivici un messaggio</a>
    ) : (
      <ContactForm />
    )}

    <div class:list={['grid grid-cols-1 sm:grid-cols-2 gap-4', compact ? 'mt-8' : 'mt-10']}>
      <a href={GITHUB_ISSUES_URL} target="_blank" rel="noopener" class="contact-card group">
        <span class="contact-card-icon" aria-hidden="true">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </span>
        <span>
          <span class="contact-card-title group-hover:text-trust transition-colors">GitHub Issues</span>
          <span class="contact-card-desc">Bug, idee e contributi al codice</span>
        </span>
      </a>

      <a href={GITHUB_URL} target="_blank" rel="noopener" class="contact-card group">
        <span class="contact-card-icon" aria-hidden="true">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
          </svg>
        </span>
        <span>
          <span class="contact-card-title group-hover:text-trust transition-colors">Repository</span>
          <span class="contact-card-desc">Codice sorgente su GitHub</span>
        </span>
      </a>

      <div class="contact-card contact-card--muted sm:col-span-2">
        <span class="contact-card-icon" aria-hidden="true">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </span>
        <span>
          <span class="contact-card-title">Hai subito una truffa?</span>
          <span class="contact-card-desc">
            Usa il <a href="/segnala" class="text-trust hover:underline">modulo segnalazione</a>, non il form contatti.
          </span>
        </span>
      </div>
    </div>

    {!compact && (
      <p class="text-sm text-ink-faint mt-8">
        Per contestare un contenuto già pubblicato, usa il
        <a href="/segnala-contenuto" class="text-trust hover:underline">modulo segnalazione contenuti</a>.
      </p>
    )}
  </div>
</section>

<style>
  .contact-card {
    @apply flex items-start gap-4 p-5 rounded-2xl border border-white/[0.1] bg-paper-card/60
           hover:border-trust/30 hover:bg-paper-elevated/40 transition-colors;
  }

  .contact-card--muted {
    @apply hover:border-white/[0.1] hover:bg-paper-card/60;
  }

  .contact-card-icon {
    @apply shrink-0 w-10 h-10 rounded-xl bg-trust/10 border border-trust/20
           flex items-center justify-center text-trust;
  }

  .contact-card-title {
    @apply block font-semibold text-ink mb-0.5;
  }

  .contact-card-desc {
    @apply block text-sm text-ink-muted leading-relaxed;
  }
</style>
