---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const articleUrl = '/truffe/esposizione-pubblica-truffatori-rischi-legali';
---

<aside class="callout-warn border-alert/25" aria-label="Avviso legale">
  <div class="flex items-start gap-3">
    <svg class="w-5 h-5 text-alert shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
    </svg>
    <div class="text-sm text-ink-muted">
      {compact ? (
        <p>
          <strong class="text-ink">Attenzione legale:</strong> in Italia esporre pubblicamente un presunto truffatore sui social — anche se hai ragione — può configurare diffamazione e violazione della privacy.
          {' '}<a href={articleUrl} class="text-trust hover:underline font-medium">Perché e cosa fare invece →</a>
        </p>
      ) : (
        <>
          <p class="font-semibold text-ink mb-2">Esporre un truffatore sui social può essere illegale</p>
          <p class="mb-2">
            In Italia, pubblicare nome, foto o accuse su Facebook, TikTok, WhatsApp o altri canali pubblici
            può costituire <strong class="text-ink">diffamazione</strong> e <strong class="text-ink">violazione della privacy</strong>,
            anche se sei stato davvero truffato. <strong class="text-ink">Avere ragione non ti protegge automaticamente.</strong>
          </p>
          <p>
            Denuncia alla <a href="https://www.commissariatodips.it/" class="text-trust hover:underline" target="_blank" rel="noopener">Polizia Postale</a>
            e racconta i fatti senza identificare pubblicamente le persone.
            {' '}<a href={articleUrl} class="text-trust hover:underline font-medium">Leggi la guida completa →</a>
          </p>
        </>
      )}
    </div>
  </div>
</aside>
