---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/truffe', label: 'Tipi di truffa' },
  { href: '/segnala', label: 'Segnala' },
  { href: '/database', label: 'Database' },
  { href: '/chi-siamo', label: 'Chi siamo' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-paper/90 backdrop-blur-md border-b border-ink/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2.5 group">
        <img src="/favicon.svg" alt="" class="w-8 h-8" width="32" height="32" />
        <span class="font-display text-xl text-ink group-hover:text-trust transition-colors">
          Truffe<span class="text-alert">.</span>info
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-1" aria-label="Navigazione principale">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'text-alert bg-alert-soft'
                : 'text-ink-muted hover:text-ink hover:bg-paper-warm',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <a href="/segnala" class="hidden md:inline-flex btn-primary text-sm !py-2 !px-4">
        Segnala una truffa
      </a>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-ink-muted hover:bg-paper-warm"
        aria-label="Apri menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <nav id="mobile-menu" class="hidden md:hidden pb-4 border-t border-ink/5 pt-3" aria-label="Menu mobile">
      <div class="flex flex-col gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2.5 text-sm font-medium rounded-lg',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'text-alert bg-alert-soft'
                : 'text-ink-muted hover:bg-paper-warm',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a href="/segnala" class="btn-primary text-sm mt-2 text-center">Segnala una truffa</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', open ? 'false' : 'true');
  });
</script>
