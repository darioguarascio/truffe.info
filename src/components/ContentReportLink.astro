---
interface Props {
  url: string;
}

const { url } = Astro.props;
const reportUrl = `/segnala-contenuto?url=${encodeURIComponent(url)}`;
---

<div class="mt-8 pt-6 border-t border-white/[0.06] flex flex-wrap items-center justify-between gap-4">
  <p class="text-xs text-ink-faint">
    Questo articolo ha scopo informativo. Le esperienze degli utenti sono soggette a moderazione.
  </p>
  <a href={reportUrl} class="text-xs text-trust hover:text-trust-dark font-medium inline-flex items-center gap-1 transition-colors">
    Segnala questo contenuto
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
  </a>
</div>
