---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import LegalNotice from '../../components/LegalNotice.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('truffe'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const legalArticleSlug = 'esposizione-pubblica-truffatori-rischi-legali';
const legalArticle = articles.find((a) => a.id.replace(/\.md$/, '') === legalArticleSlug);
const otherArticles = articles.filter((a) => a.id.replace(/\.md$/, '') !== legalArticleSlug);
---

<PageLayout
  title="Tipi di truffa | Truffe.info"
  description="Guide complete sulle truffe più comuni in Italia: phishing, smishing, falso tecnico, truffe romantiche e altro."
>
  <PageHero
    eyebrow="Knowledge base"
    title="Tipi di truffa"
    description="Conosci le tecniche usate dai truffatori per difenderti meglio. Ogni guida spiega come funziona la truffa, i segnali d'allarme e cosa fare."
  />

  <div class="page-container py-12 md:py-16">
    <LegalNotice />

    {legalArticle && (
      <a href={`/truffe/${legalArticleSlug}`} class="group article-card block mt-8 mb-10 border-accent/20">
        <div class="h-1 bg-gradient-to-r from-accent via-alert/80 to-alert"></div>
        <div class="p-6">
          <span class="tag border-accent/30 text-accent mb-3">Importante — legge italiana</span>
          <h2 class="font-display text-2xl font-semibold text-ink group-hover:text-trust transition-colors mb-2">
            {legalArticle.data.title}
          </h2>
          <p class="text-sm text-ink-muted">{legalArticle.data.description}</p>
        </div>
      </a>
    )}

    <div class="flex items-center justify-between mb-8">
      <p class="text-sm font-mono text-ink-faint">{articles.length} guide disponibili</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {otherArticles.map((article) => (
        <a
          href={`/truffe/${article.id.replace(/\.md$/, '')}`}
          class="group article-card"
        >
          <div class="h-1 bg-gradient-to-r from-trust/80 via-accent/50 to-alert/60"></div>
          <div class="p-6 flex-1 flex flex-col">
            <div class="flex flex-wrap gap-2 mb-4">
              {article.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <h2 class="font-display text-2xl font-semibold text-ink group-hover:text-trust transition-colors mb-2">
              {article.data.title}
            </h2>
            <p class="text-sm text-ink-muted flex-1 leading-relaxed">{article.data.description}</p>
            <div class="flex items-center justify-between mt-5 pt-4 border-t border-white/[0.06]">
              <time datetime={article.data.date.toISOString()} class="text-xs font-mono text-ink-faint">
                {article.data.date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <span class="text-sm text-trust font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                Leggi
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</PageLayout>
