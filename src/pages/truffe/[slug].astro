---
import PageLayout from '../../layouts/PageLayout.astro';
import ContentReportLink from '../../components/ContentReportLink.astro';
import LegalNotice from '../../components/LegalNotice.astro';
import { getEntry, render } from 'astro:content';
import { formatDateIT } from '../../lib/dates';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/truffe');

const article = await getEntry('truffe', slug);
if (!article) return Astro.redirect('/404');

const { Content } = await render(article);

const title = article.data.meta_title ?? `${article.data.title} | Truffe.info`;
const description = article.data.meta_description ?? article.data.description;
---

<PageLayout title={title} description={description}>
  <article class="article-reading">
    <header class="mb-10 pb-8 border-b border-white/[0.08] max-w-[42rem]">
      <a href="/truffe" class="inline-flex items-center gap-1.5 text-sm text-ink-faint hover:text-trust transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
        Tutte le guide
      </a>
      <div class="flex flex-wrap gap-2 mb-5">
        {article.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      <h1 class="font-display text-3xl md:text-[2.75rem] font-bold text-ink tracking-tight leading-[1.15] mb-5">
        {article.data.title}
      </h1>
      <p class="text-lg md:text-xl text-ink-muted leading-relaxed mb-4">{article.data.description}</p>
      <time datetime={article.data.date.toISOString()} class="text-sm text-ink-muted">
        Aggiornato il {formatDateIT(article.data.date)}
      </time>
    </header>

    <div class="prose-truffe">
      <Content />
    </div>

    <footer class="mt-14 pt-8 border-t border-white/[0.08] max-w-[42rem]">
      <LegalNotice compact />

      <div class="callout-warn mb-8 mt-6">
        <h2 class="font-display text-lg font-semibold text-ink mb-2">Ti è successo qualcosa di simile?</h2>
        <p class="text-sm text-ink-body mb-4">
          Segnala la truffa per aiutare altri a riconoscerla. Anche un tentativo non riuscito è utile.
        </p>
        <a href="/segnala" class="btn-primary text-sm">Segnala una truffa</a>
      </div>
      <ContentReportLink url={`https://truffe.info/truffe/${slug}`} />
    </footer>
  </article>
</PageLayout>
