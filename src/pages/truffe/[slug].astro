---
import PageLayout from '../../layouts/PageLayout.astro';
import ContentReportLink from '../../components/ContentReportLink.astro';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/truffe');

const article = await getEntry('truffe', slug);
if (!article) return Astro.redirect('/404');

const { Content } = await render(article);

const title = article.data.meta_title ?? `${article.data.title} | Truffe.info`;
const description = article.data.meta_description ?? article.data.description;
---

<PageLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <header class="mb-10 pb-8 border-b border-ink/10">
      <div class="flex flex-wrap gap-2 mb-4">
        {article.data.tags.map((tag) => (
          <span class="text-xs font-medium px-2.5 py-1 bg-trust-light text-trust rounded-full">{tag}</span>
        ))}
      </div>
      <h1 class="font-display text-3xl md:text-4xl text-ink mb-4">{article.data.title}</h1>
      <p class="text-lg text-ink-muted mb-4">{article.data.description}</p>
      <time datetime={article.data.date.toISOString()} class="text-sm text-ink-faint">
        Aggiornato il {article.data.date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
      </time>
    </header>

    <div class="prose-truffe">
      <Content />
    </div>

    <footer class="mt-12 pt-8 border-t border-ink/10">
      <div class="bg-alert-soft rounded-xl p-6">
        <h2 class="font-semibold text-ink mb-2">Hai avuto un'esperienza simile?</h2>
        <p class="text-sm text-ink-muted mb-4">
          Segnala la truffa per aiutare altri a riconoscerla. Anche un tentativo non riuscito è utile.
        </p>
        <a href="/segnala" class="btn-primary text-sm">Segnala una truffa</a>
      </div>
      <ContentReportLink url={`https://truffe.info/truffe/${slug}`} />
      <a href="/truffe" class="inline-block mt-6 text-sm text-trust hover:underline">← Torna alle guide</a>
    </footer>
  </article>
</PageLayout>
