---
import PageLayout from '../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('truffe');
const articles = allArticles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<PageLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-trust/5 via-paper to-accent-soft/30"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-alert/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="max-w-2xl">
        <p class="text-trust text-sm font-semibold tracking-wide uppercase mb-4">
          Protezione collettiva
        </p>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-ink leading-tight mb-6">
          Aiutaci a smascherare i truffatori
        </h1>
        <p class="text-lg text-ink-muted leading-relaxed mb-8">
          Segnala la tua esperienza e contribuisci al database collettivo
          di informazioni sulle truffe online in Italia.
          Anche un tentativo non riuscito fa la differenza.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/segnala" class="btn-primary">Segnala una truffa</a>
          <a href="/truffe" class="btn-secondary">Esplora le truffe</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-ink/5 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        <div>
          <p class="font-display text-3xl text-ink mb-1">{allArticles.length}+</p>
          <p class="text-sm text-ink-muted">Guide sulle truffe più comuni</p>
        </div>
        <div>
          <p class="font-display text-3xl text-ink mb-1">100%</p>
          <p class="text-sm text-ink-muted">Open source e gratuito</p>
        </div>
        <div>
          <p class="font-display text-3xl text-ink mb-1">🇮🇹</p>
          <p class="text-sm text-ink-muted">Focus sul mercato italiano</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <h2 class="font-display text-3xl text-ink mb-3">Come funziona</h2>
    <p class="text-ink-muted mb-10 max-w-xl">
      Un archivio collaborativo per documentare truffe, tecniche e profili di truffatori.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white rounded-xl p-6 shadow-card border border-ink/5">
        <div class="w-10 h-10 rounded-lg bg-trust-light flex items-center justify-center text-trust font-bold mb-4">1</div>
        <h3 class="font-semibold text-ink mb-2">Informati</h3>
        <p class="text-sm text-ink-muted">Leggi le guide sulle truffe più diffuse e impara a riconoscere i segnali d'allarme.</p>
      </div>
      <div class="bg-white rounded-xl p-6 shadow-card border border-ink/5">
        <div class="w-10 h-10 rounded-lg bg-alert-soft flex items-center justify-center text-alert font-bold mb-4">2</div>
        <h3 class="font-semibold text-ink mb-2">Segnala</h3>
        <p class="text-sm text-ink-muted">Racconta la tua esperienza con il modulo guidato. Puoi allegare prove e documentazione.</p>
      </div>
      <div class="bg-white rounded-xl p-6 shadow-card border border-ink/5">
        <div class="w-10 h-10 rounded-lg bg-accent-soft flex items-center justify-center text-accent font-bold mb-4">3</div>
        <h3 class="font-semibold text-ink mb-2">Proteggi</h3>
        <p class="text-sm text-ink-muted">Le segnalazioni alimentano il database pubblico e aiutano altri a non cadere nella stessa trappola.</p>
      </div>
    </div>
  </section>

  <!-- Latest articles -->
  <section class="bg-paper-warm border-t border-ink/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="font-display text-3xl text-ink mb-2">Ultime guide</h2>
          <p class="text-ink-muted">Approfondimenti sulle truffe più comuni in Italia</p>
        </div>
        <a href="/truffe" class="hidden sm:inline-flex btn-ghost text-trust">Vedi tutte →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {articles.map((article) => (
          <a href={`/truffe/${article.id}`} class="group bg-white rounded-xl overflow-hidden shadow-card border border-ink/5 hover:shadow-lift transition-shadow">
            <div class="h-2 bg-gradient-to-r from-trust to-alert"></div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {article.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-xs font-medium px-2 py-0.5 bg-trust-light text-trust rounded-full">{tag}</span>
                ))}
              </div>
              <h3 class="font-display text-xl text-ink group-hover:text-trust transition-colors mb-2">
                {article.data.title}
              </h3>
              <p class="text-sm text-ink-muted line-clamp-3">{article.data.description}</p>
              <time datetime={article.data.date.toISOString()} class="block text-xs text-ink-faint mt-4">
                {article.data.date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
            </div>
          </a>
        ))}
      </div>

      <a href="/truffe" class="sm:hidden btn-secondary w-full mt-6 text-center">Vedi tutte le guide</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="bg-ink rounded-2xl p-8 md:p-12 text-center">
      <h2 class="font-display text-2xl md:text-3xl text-white mb-4">
        Hai subito o tentato una truffa?
      </h2>
      <p class="text-white/70 mb-8 max-w-lg mx-auto">
        La tua segnalazione può salvare qualcun altro. Compila il modulo in pochi minuti — i tuoi dati sono protetti.
      </p>
      <a href="/segnala" class="inline-flex btn-primary bg-alert hover:bg-red-700">
        Segnala ora
      </a>
    </div>
  </section>
</PageLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
