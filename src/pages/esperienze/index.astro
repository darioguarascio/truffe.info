---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getApprovedExperiences } from '../../lib/db';
import { experienceTitle, experienceExcerpt, experienceDate } from '../../lib/experiences';

const experiences = await getApprovedExperiences();
---

<PageLayout
  title="Esperienze | Truffe.info"
  description="Storie personali di persone che hanno subito o rischiato una truffa in Italia. Letture moderate dalla community."
>
  <PageHero
    eyebrow="Community"
    title="Esperienze reali"
    description="Storie raccontate in prima persona da chi ha vissuto una truffa o un tentativo. Ogni resoconto è moderato prima della pubblicazione."
  />

  <div class="page-container py-12 md:py-16">
    <div class="callout-info mb-10 max-w-3xl">
      <p class="text-sm text-ink-muted">
        I nomi degli autori non vengono pubblicati. I contenuti riflettono l'esperienza personale
        di chi segnala e sono soggetti alle <a href="/linee-guida" class="text-trust hover:underline">linee guida</a>.
      </p>
    </div>

    {experiences.length === 0 ? (
      <div class="glass-card p-10 md:p-14 text-center max-w-2xl mx-auto">
        <div class="w-16 h-16 rounded-2xl bg-white/[0.04] border border-white/[0.08] flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-ink-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
          </svg>
        </div>
        <h2 class="font-display text-2xl font-semibold text-ink mb-2">Nessuna esperienza pubblicata ancora</h2>
        <p class="text-sm text-ink-muted mb-8 max-w-md mx-auto">
          Le storie verranno pubblicate dopo la moderazione. Sii il primo a condividere la tua.
        </p>
        <a href="/segnala" class="btn-primary text-sm">Racconta la tua esperienza</a>
      </div>
    ) : (
      <>
        <p class="text-sm font-mono text-ink-faint mb-8">{experiences.length} {experiences.length === 1 ? 'storia' : 'storie'} pubblicate</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {experiences.map((exp) => (
            <a href={`/esperienze/${exp.id}`} class="group article-card">
              <div class="h-1 bg-gradient-to-r from-trust/80 via-accent/50 to-alert/60"></div>
              <div class="p-6 flex flex-col flex-1">
                {exp.location && (
                  <span class="tag mb-4 w-fit">{exp.location}</span>
                )}
                <h2 class="font-display text-xl font-semibold text-ink group-hover:text-trust transition-colors mb-2 line-clamp-2">
                  {experienceTitle(exp)}
                </h2>
                <p class="text-sm text-ink-muted flex-1 leading-relaxed line-clamp-3">
                  {experienceExcerpt(exp)}
                </p>
                <div class="flex flex-wrap items-center gap-3 mt-5 pt-4 border-t border-white/[0.06] text-xs font-mono text-ink-faint">
                  <time datetime={experienceDate(exp).toISOString()}>
                    {experienceDate(exp).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  {exp.money_taken === true && <span class="text-alert">Denaro sottratto</span>}
                  {exp.money_taken === false && <span class="text-trust">Tentativo bloccato</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</PageLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
