---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Segnala una truffa | Truffe.info" description="Modulo di segnalazione truffe. Racconta la tua esperienza e contribuisci al database collettivo.">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <header class="mb-8">
      <h1 class="font-display text-3xl md:text-4xl text-ink mb-2">Modulo segnalazione truffa</h1>
      <p class="text-ink-muted">Anche un tentativo non riuscito contribuisce alla profilazione</p>
    </header>

    <div class="bg-trust-light border border-trust/20 rounded-xl p-4 mb-8 text-sm text-ink-muted">
      <p class="font-semibold text-ink mb-2">Prima di iniziare — regole importanti</p>
      <ul class="list-disc pl-5 space-y-1">
        <li>Racconta <strong>la tua esperienza</strong> in prima persona, senza insulti o accuse non dimostrabili</li>
        <li>Non inserire dati personali di terzi (indirizzi, codici fiscali, email private)</li>
        <li>Evita affermazioni categoriche su persone fisiche (es. "X è un criminale")</li>
        <li>La segnalazione <strong>non sarà pubblicata</strong> finché non verrà moderata</li>
      </ul>
      <p class="mt-2">Leggi le <a href="/linee-guida" class="text-trust hover:underline font-medium">linee guida complete</a>.</p>
    </div>

    <!-- Progress bar -->
    <div class="mb-8">
      <div class="flex justify-between text-xs text-ink-faint mb-2">
        <span id="step-label">Passo 1 di 5</span>
        <span id="step-name">Informazioni base</span>
      </div>
      <div class="h-1.5 bg-paper-warm rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-trust transition-all duration-300 rounded-full" style="width: 20%"></div>
      </div>
    </div>

    <form id="segnala-form" class="bg-white rounded-xl shadow-card border border-ink/5 p-6 md:p-8" enctype="multipart/form-data">
      <!-- Step 1: Basic info -->
      <div class="form-step" data-step="1">
        <h2 class="font-display text-xl text-ink mb-6 pb-3 border-b border-ink/10">Informazioni sulla truffa</h2>

        <div class="space-y-5">
          <div>
            <label class="form-label" for="location">Dove è avvenuta la truffa</label>
            <input type="text" id="location" name="location" class="form-input" placeholder="Es. sito web, telefono, di persona..." />
            <p class="form-hint">Se online, inserisci il sito web dove è avvenuto il primo contatto</p>
          </div>

          <div>
            <label class="form-label" for="amount">Importo della truffa</label>
            <input type="number" id="amount" name="amount" class="form-input" min="0" step="0.01" placeholder="0.00" />
            <p class="form-hint">Indica di quanto denaro si tratta (€). Lascia vuoto se non applicabile.</p>
          </div>

          <div>
            <p class="form-label">Il truffatore è riuscito a sottrarti il denaro?</p>
            <div class="flex gap-4 mt-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="money_taken" value="si" class="accent-trust" />
                <span class="text-sm">Sì</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="money_taken" value="no" class="accent-trust" />
                <span class="text-sm">No</span>
              </label>
            </div>
          </div>

          <div>
            <p class="form-label">Hai sporto denuncia alle autorità?</p>
            <div class="flex gap-4 mt-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="reported_to_police" value="si" class="accent-trust" />
                <span class="text-sm">Sì</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="reported_to_police" value="no" class="accent-trust" />
                <span class="text-sm">No</span>
              </label>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Timeline -->
      <div class="form-step hidden" data-step="2">
        <h2 class="font-display text-xl text-ink mb-2">Descrizione della truffa</h2>
        <p class="text-sm text-ink-muted mb-4">
          Descrivi gli avvenimenti in ordine cronologico. Usa la prima persona:
          <em>"Ho ricevuto una chiamata...", "Mi è arrivato un messaggio..."</em>
        </p>
        <div class="bg-accent-soft border border-accent/30 rounded-lg p-3 mb-6 text-xs text-ink-muted">
          Non usare insulti né accusare persone per nome completo. Descrivi i fatti accaduti a te.
        </div>

        <div id="events-container" class="space-y-6">
          <div class="event-item border border-ink/10 rounded-lg p-4">
            <div class="grid grid-cols-2 gap-3 mb-3">
              <div>
                <label class="form-label text-xs">Data</label>
                <input type="date" class="form-input event-date" />
              </div>
              <div>
                <label class="form-label text-xs">Ora</label>
                <input type="time" class="form-input event-time" />
              </div>
            </div>
            <div>
              <label class="form-label text-xs">Descrizione</label>
              <textarea class="form-input event-description min-h-[100px] resize-y" placeholder="Descrivi cosa è successo..."></textarea>
            </div>
          </div>
        </div>

        <button type="button" id="add-event" class="mt-4 btn-ghost text-trust border border-trust/20 w-full">
          + Aggiungi un altro evento
        </button>
      </div>

      <!-- Step 3: Files -->
      <div class="form-step hidden" data-step="3">
        <h2 class="font-display text-xl text-ink mb-2">Documentazione e file</h2>
        <p class="text-sm text-ink-muted mb-6">
          Se disponi di materiale multimediale (audio, video, foto, ecc.), caricalo qui.
        </p>

        <div
          id="drop-zone"
          class="border-2 border-dashed border-ink/15 rounded-xl p-10 text-center hover:border-trust/40 transition-colors cursor-pointer"
        >
          <svg class="w-12 h-12 mx-auto text-trust/40 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
          <p class="font-semibold text-ink mb-1">Sfoglia file</p>
          <p class="text-xs text-ink-faint">Trascina i file qui o clicca per selezionarli</p>
          <p class="text-xs text-ink-faint mt-2">Max 25 MB per file. JPG, PNG, PDF, MP3, MP4</p>
          <input type="file" id="file-input" name="attachments" multiple accept="image/*,audio/*,video/*,application/pdf,text/plain" class="hidden" />
        </div>

        <ul id="file-list" class="mt-4 space-y-2"></ul>
      </div>

      <!-- Step 4: Scammer -->
      <div class="form-step hidden" data-step="4">
        <h2 class="font-display text-xl text-ink mb-6 pb-3 border-b border-ink/10">Identificazione truffatore</h2>

        <div class="space-y-5">
          <div>
            <p class="text-sm text-ink-muted mb-3">
              Sei riuscito a identificare il truffatore dal nostro
              <a href="/database" class="text-trust hover:underline">database pubblico</a>?
              Inserisci il suo nome in codice.
            </p>
            <label class="form-label" for="scammer_codename">Nome in codice del truffatore</label>
            <input type="text" id="scammer_codename" name="scammer_codename" class="form-input" />
          </div>

          <hr class="border-ink/10" />

          <p class="text-sm text-ink-muted">
            Se non hai trovato riscontri nel database, puoi fornire un identikit generico.
            <strong>Non inserire nomi completi di persone reali</strong> né dati personali non necessari.
          </p>

          <div class="bg-alert-soft border border-alert/20 rounded-lg p-3 text-xs text-ink-muted">
            I dati in questa sezione sono usati solo per moderazione interna e non vengono pubblicati automaticamente.
            Numeri di telefono e nomi verranno anonimizzati prima di qualsiasi pubblicazione.
          </div>

          <div>
            <p class="form-label">Sesso</p>
            <div class="flex gap-4 mt-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="scammer_gender" value="male" class="accent-trust" />
                <span class="text-sm">Uomo</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="scammer_gender" value="female" class="accent-trust" />
                <span class="text-sm">Donna</span>
              </label>
            </div>
          </div>

          <div>
            <label class="form-label" for="scammer_nationality">Nazionalità</label>
            <input type="text" id="scammer_nationality" name="scammer_nationality" class="form-input" />
            <p class="form-hint">Italiano o straniero</p>
          </div>

          <div>
            <label class="form-label" for="scammer_name">Nome usato dal truffatore (se falso)</label>
            <input type="text" id="scammer_name" name="scammer_name" class="form-input" placeholder="Es. Marco, Dr. Bianchi..." />
            <p class="form-hint">Solo nomi o alias usati durante la truffa — non nomi completi di persone reali identificate</p>
          </div>

          <div>
            <label class="form-label" for="scammer_phone">Numero di telefono usato</label>
            <input type="tel" id="scammer_phone" name="scammer_phone" class="form-input" />
            <p class="form-hint">Solo se rilevante per la segnalazione. Verrà anonimizzato in pubblicazione.</p>
          </div>

          <div>
            <label class="form-label" for="scammer_characteristics">Caratteristiche e segni particolari</label>
            <textarea id="scammer_characteristics" name="scammer_characteristics" class="form-input min-h-[100px] resize-y" placeholder="Accenti, tonalità della voce, particolari che potrebbero essere d'aiuto..."></textarea>
          </div>
        </div>
      </div>

      <!-- Step 5: Personal + Declaration -->
      <div class="form-step hidden" data-step="5">
        <h2 class="font-display text-xl text-ink mb-6 pb-3 border-b border-ink/10">I tuoi dati</h2>

        <div class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="form-label" for="reporter_first_name">Nome *</label>
              <input type="text" id="reporter_first_name" name="reporter_first_name" class="form-input" required />
            </div>
            <div>
              <label class="form-label" for="reporter_last_name">Cognome *</label>
              <input type="text" id="reporter_last_name" name="reporter_last_name" class="form-input" required />
            </div>
          </div>

          <div>
            <label class="form-label" for="reporter_email">Email *</label>
            <input type="email" id="reporter_email" name="reporter_email" class="form-input" required />
            <p class="form-hint">Servirà per mettersi in contatto con te per comunicarti eventuali aggiornamenti</p>
          </div>

          <hr class="border-ink/10" />

          <div class="space-y-3">
            <div class="bg-paper-warm rounded-lg p-4 border border-ink/10">
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" id="declaration" name="declaration_accepted" required class="mt-1 accent-trust" />
                <span class="text-sm text-ink-muted leading-relaxed">
                  <strong class="text-ink">Dichiarazione di veridicità:</strong> dichiaro che le informazioni fornite
                  descrivono la mia esperienza personale ed sono veritiere al meglio delle mie conoscenze.
                  Sono consapevole che false dichiarazioni possono costituire reato.
                  Acconsento alla conservazione dei metadati di invio (IP, data/ora) per finalità legali.
                </span>
              </label>
            </div>

            <div class="bg-paper-warm rounded-lg p-4 border border-ink/10">
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" id="terms" name="terms_accepted" required class="mt-1 accent-trust" />
                <span class="text-sm text-ink-muted leading-relaxed">
                  Ho letto e accetto i <a href="/termini" target="_blank" class="text-trust hover:underline">Termini di utilizzo</a>
                  e sono responsabile del contenuto che invio.
                </span>
              </label>
            </div>

            <div class="bg-paper-warm rounded-lg p-4 border border-ink/10">
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" id="guidelines" name="guidelines_accepted" required class="mt-1 accent-trust" />
                <span class="text-sm text-ink-muted leading-relaxed">
                  Ho letto e accetto le <a href="/linee-guida" target="_blank" class="text-trust hover:underline">Linee guida della community</a>:
                  non pubblicherò insulti, accuse non dimostrabili o dati personali di terzi.
                </span>
              </label>
            </div>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <div class="flex justify-between mt-8 pt-6 border-t border-ink/10">
        <button type="button" id="btn-prev" class="btn-ghost hidden">← Indietro</button>
        <div class="flex-1"></div>
        <button type="button" id="btn-next" class="btn-primary">Avanti →</button>
        <button type="submit" id="btn-submit" class="btn-primary hidden">Invia segnalazione</button>
      </div>

      <div id="form-error" class="hidden mt-4 p-3 bg-alert-soft text-alert text-sm rounded-lg"></div>
    </form>

    <!-- Success message -->
    <div id="success-message" class="hidden bg-white rounded-xl shadow-card border border-ink/5 p-8 md:p-12 text-center">
      <div class="w-16 h-16 bg-trust-light rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-trust" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h2 class="font-display text-2xl text-ink mb-2">Segnalazione inviata</h2>
      <p class="text-ink-muted mb-6">Grazie. La tua segnalazione è in attesa di moderazione e non sarà pubblica finché non verrà esaminata.</p>
      <a href="/" class="btn-secondary">Torna alla home</a>
    </div>
  </div>
</PageLayout>

<script>
  const STEPS = [
    { name: 'Informazioni base' },
    { name: 'Descrizione' },
    { name: 'Documentazione' },
    { name: 'Truffatore' },
    { name: 'I tuoi dati' },
  ];

  let currentStep = 1;
  const totalSteps = STEPS.length;
  const selectedFiles = [];

  const form = document.getElementById('segnala-form');
  const steps = document.querySelectorAll('.form-step');
  const progressBar = document.getElementById('progress-bar');
  const stepLabel = document.getElementById('step-label');
  const stepName = document.getElementById('step-name');
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');
  const btnSubmit = document.getElementById('btn-submit');
  const formError = document.getElementById('form-error');
  const successMessage = document.getElementById('success-message');

  function showStep(step) {
    currentStep = step;
    steps.forEach((el) => {
      const s = parseInt(el.dataset.step || '0');
      el.classList.toggle('hidden', s !== step);
    });
    progressBar.style.width = `${(step / totalSteps) * 100}%`;
    stepLabel.textContent = `Passo ${step} di ${totalSteps}`;
    stepName.textContent = STEPS[step - 1].name;
    btnPrev.classList.toggle('hidden', step === 1);
    btnNext.classList.toggle('hidden', step === totalSteps);
    btnSubmit.classList.toggle('hidden', step !== totalSteps);
    formError.classList.add('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function validateStep(step) {
    if (step === 5) {
      const firstName = document.getElementById('reporter_first_name').value.trim();
      const lastName = document.getElementById('reporter_last_name').value.trim();
      const email = document.getElementById('reporter_email').value.trim();
      const declaration = document.getElementById('declaration').checked;
      const terms = document.getElementById('terms').checked;
      const guidelines = document.getElementById('guidelines').checked;
      if (!firstName || !lastName || !email) {
        formError.textContent = 'Compila tutti i campi obbligatori.';
        formError.classList.remove('hidden');
        return false;
      }
      if (!declaration || !terms || !guidelines) {
        formError.textContent = 'Devi accettare tutte le dichiarazioni e i termini.';
        formError.classList.remove('hidden');
        return false;
      }
    }
    return true;
  }

  btnNext.addEventListener('click', () => {
    if (validateStep(currentStep) && currentStep < totalSteps) {
      showStep(currentStep + 1);
    }
  });

  btnPrev.addEventListener('click', () => {
    if (currentStep > 1) showStep(currentStep - 1);
  });

  // Eventi timeline
  document.getElementById('add-event')?.addEventListener('click', () => {
    const container = document.getElementById('events-container');
    const template = container.querySelector('.event-item').cloneNode(true);
    template.querySelectorAll('input, textarea').forEach((el) => {
      el.value = '';
    });
    container.appendChild(template);
  });

  // File upload
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input');
  const fileList = document.getElementById('file-list');

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-trust'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-trust'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-trust');
    if (e.dataTransfer?.files) addFiles(Array.from(e.dataTransfer.files));
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files) addFiles(Array.from(fileInput.files));
  });

  function addFiles(files) {
    files.forEach((f) => {
      if (!selectedFiles.some((s) => s.name === f.name && s.size === f.size)) {
        selectedFiles.push(f);
      }
    });
    renderFileList();
  }

  function renderFileList() {
    fileList.innerHTML = selectedFiles.map((f, i) =>
      `<li class="flex items-center justify-between text-sm bg-paper-warm px-3 py-2 rounded-lg">
        <span class="truncate">${f.name} (${(f.size / 1024).toFixed(0)} KB)</span>
        <button type="button" data-index="${i}" class="text-alert hover:underline ml-2 shrink-0">Rimuovi</button>
      </li>`
    ).join('');
    fileList.querySelectorAll('button').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedFiles.splice(parseInt(btn.dataset.index), 1);
        renderFileList();
      });
    });
  }

  function collectEvents() {
    return Array.from(document.querySelectorAll('.event-item')).map((item) => ({
      date: item.querySelector('.event-date').value,
      time: item.querySelector('.event-time').value,
      description: item.querySelector('.event-description').value,
    })).filter((e) => e.description.trim());
  }

  function getRadio(name) {
    const checked = form.querySelector(`input[name="${name}"]:checked`);
    if (!checked) return undefined;
    return checked.value === 'si';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateStep(5)) return;

    btnSubmit.setAttribute('disabled', 'true');
    btnSubmit.textContent = 'Invio in corso...';
    formError.classList.add('hidden');

    const fd = new FormData();
    fd.append('location', document.getElementById('location').value);
    fd.append('amount', document.getElementById('amount').value);
    fd.append('money_taken', String(getRadio('money_taken') ?? ''));
    fd.append('reported_to_police', String(getRadio('reported_to_police') ?? ''));
    fd.append('events', JSON.stringify(collectEvents()));
    fd.append('scammer_codename', document.getElementById('scammer_codename').value);
    fd.append('scammer_gender', form.querySelector('input[name="scammer_gender"]:checked')?.value ?? '');
    fd.append('scammer_nationality', document.getElementById('scammer_nationality').value);
    fd.append('scammer_name', document.getElementById('scammer_name').value);
    fd.append('scammer_phone', document.getElementById('scammer_phone').value);
    fd.append('scammer_characteristics', document.getElementById('scammer_characteristics').value);
    fd.append('reporter_first_name', document.getElementById('reporter_first_name').value);
    fd.append('reporter_last_name', document.getElementById('reporter_last_name').value);
    fd.append('reporter_email', document.getElementById('reporter_email').value);
    fd.append('declaration_accepted', 'true');
    fd.append('terms_accepted', 'true');
    fd.append('guidelines_accepted', 'true');
    selectedFiles.forEach((f) => fd.append('attachments', f));

    try {
      const res = await fetch('/api/reports', { method: 'POST', body: fd });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Errore durante l\'invio');
      form.classList.add('hidden');
      document.querySelector('header')?.classList.add('hidden');
      document.getElementById('progress-bar')?.parentElement?.parentElement?.classList.add('hidden');
      successMessage.classList.remove('hidden');
    } catch (err) {
      formError.textContent = err instanceof Error ? err.message : 'Errore durante l\'invio. Riprova.';
      formError.classList.remove('hidden');
      btnSubmit.removeAttribute('disabled');
      btnSubmit.textContent = 'Invia segnalazione';
    }
  });
</script>
